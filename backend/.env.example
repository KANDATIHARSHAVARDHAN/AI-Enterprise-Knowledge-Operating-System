# ============================================
# EKOS Environment Configuration
# Copy this to .env and fill in your values
# ============================================

# === LLM Configuration ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_FAST=mixtral-8x7b-32768

# === Embedding Configuration ===
GOOGLE_API_KEY=your_google_api_key_here
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSION=768

# === Database Provider ===
DATABASE_PROVIDER=firestore  # Set to 'firestore' for production or 'mysql' for local development

# === MySQL Configuration ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ekos_db

# === Firebase Configuration (Required if DATABASE_PROVIDER=firestore) ===
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here.appspot.com

# === Pinecone Vector Database ===
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=ekos-index



# === JWT Configuration ===
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Application Configuration ===
APP_NAME=EKOS
APP_VERSION=1.0.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# === File Upload ===
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# === RAG Configuration ===
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
DENSE_WEIGHT=0.6
SPARSE_WEIGHT=0.4

# === FAISS Configuration ===
FAISS_INDEX_PATH=vector_store/faiss_index
FAISS_METADATA_PATH=vector_store/metadata.json

# === Knowledge Graph ===
KNOWLEDGE_GRAPH_PATH=knowledge_graph.json

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ekos-evaluation

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/ekos.log
